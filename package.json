{
    "name": "be-worker-template",
    "description": "Cloudflare Worker for backend API",
    "type": "module",
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy --minify",
        "cf-typegen": "wrangler types --env-interface CloudflareBindings",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:studio": "drizzle-kit studio",
        "commitlint": "commitlint --edit",
        "format": "prettier --write .",
        "prepare": "husky"
    },
    "dependencies": {
        "@hono/mcp": "^0.2.3",
        "@hono/swagger-ui": "^0.5.3",
        "@hono/zod-openapi": "^1.2.1",
        "axios": "^1.13.5",
        "bcryptjs": "^3.0.3",
        "drizzle-orm": "^0.45.1",
        "drizzle-zod": "^0.8.3",
        "hono": "^4.11.9",
        "pg": "^8.18.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@commitlint/config-conventional": "^20.4.1",
        "@types/node": "^25.2.3",
        "@types/pg": "^8",
        "commitlint": "^20.4.1",
        "dotenv": "^17.3.1",
        "drizzle-kit": "^0.31.9",
        "husky": "^9.1.7",
        "jsonc-parser": "^3.3.1",
        "postgres": "^3.4.8",
        "prettier": "^3.8.1",
        "wrangler": "^4.65.0"
    },
    "packageManager": "yarn@4.12.0"
}
