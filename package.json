{
    "name": "be-worker-template",
    "version": "0.0.0",
    "description": "Cloudflare Worker for backend API",
    "type": "module",
    "scripts": {
        "dev": "wrangler dev",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "deploy": "wrangler deploy --minify",
        "cf-typegen": "wrangler types --env-interface CloudflareBindings",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:studio": "drizzle-kit studio",
        "format": "prettier --write .",
        "prepare": "simple-git-hooks"
    },
    "dependencies": {
        "@hono/mcp": "^0.2.3",
        "@hono/swagger-ui": "^0.5.3",
        "@hono/zod-openapi": "^1.2.1",
        "axios": "^1.13.5",
        "bcryptjs": "^3.0.3",
        "drizzle-orm": "^0.45.1",
        "drizzle-zod": "^0.8.3",
        "hono": "^4.11.9",
        "pg": "^8.18.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@cloudflare/vitest-pool-workers": "^0.14.1",
        "@commitlint/config-conventional": "^20.4.1",
        "@types/node": "^25.2.3",
        "@types/pg": "^8",
        "commitlint": "^20.4.1",
        "dotenv": "^17.3.1",
        "drizzle-kit": "^0.31.9",
        "jsonc-parser": "^3.3.1",
        "prettier": "^3.8.1",
        "simple-git-hooks": "^2.13.1",
        "vitest": "^4.1.2",
        "wrangler": "^4.65.0"
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ]
    },
    "simple-git-hooks": {
        "pre-commit": "pnpm format",
        "commit-msg": "pnpm commitlint --edit $1"
    },
    "packageManager": "pnpm@10.33.0",
    "pnpm": {
        "onlyBuiltDependencies": [
            "simple-git-hooks"
        ]
    }
}